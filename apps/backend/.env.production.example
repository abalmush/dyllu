# Production env for the Medusa backend (apps/backend). Coolify injects these
# into the container; this file is a checked-in template with documentation.

# ---- Runtime ----
NODE_ENV=production

# ---- Database (Postgres) ----
# Format: postgres://USER:PASS@HOST:PORT/DB
# In Coolify, attach a Postgres service to this app and copy its URL here.
DATABASE_URL=
# Use false only for the current same-host private Docker network. Use true for
# managed or remote Postgres, and keep certificate verification enabled.
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# ---- Redis ----
# Required in production for the Event Bus, Cache, Workflow engine locking.
# Dev defaults to in-memory fakes but those are not safe for prod.
REDIS_URL=

# ---- CORS ----
# Comma-separated. Include every origin that will hit the API.
# STORE_CORS = storefront origins (Cloudflare Worker custom domains)
# ADMIN_CORS = backend's own domain (admin UI calls its own API)
# AUTH_CORS  = everything that performs login flows (storefront + admin)
STORE_CORS=https://dyllu.md,https://www.dyllu.md
ADMIN_CORS=https://api.dyllu.md
AUTH_CORS=https://dyllu.md,https://www.dyllu.md,https://api.dyllu.md

# ---- Secrets ----
# Generate with: openssl rand -hex 64
JWT_SECRET=
COOKIE_SECRET=

# ---- Storefront cache revalidation ----
# Required by backend scripts that invalidate the storefront cache. This secret
# must exactly match the storefront Worker's REVALIDATE_SECRET secret.
STOREFRONT_URL=https://dyllu.md
REVALIDATE_SECRET=

# ---- File storage (S3-compatible — recommend Cloudflare R2) ----
# Needed for product images and admin uploads.
S3_FILE_URL=https://cdn.yourdomain.tld
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_BUCKET=
S3_ENDPOINT=https://<cf-account-id>.r2.cloudflarestorage.com

# ---- Optional but recommended ----
# Medusa admin email notifications via Resend
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# Sentry for error tracking
# SENTRY_DSN=
