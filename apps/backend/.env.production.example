# Production env for the Medusa backend (apps/backend). Coolify injects these
# into the container; this file is a checked-in template with documentation.

# ---- Database (Postgres) ----
# Format: postgres://USER:PASS@HOST:PORT/DB
# In Coolify, attach a Postgres service to this app and copy its URL here.
DATABASE_URL=

# ---- Redis ----
# Required in production for the Event Bus, Cache, Workflow engine locking.
# Dev defaults to in-memory fakes but those are not safe for prod.
REDIS_URL=

# ---- CORS ----
# Comma-separated. Include every origin that will hit the API.
# STORE_CORS = storefront origins (Vercel)
# ADMIN_CORS = backend's own domain (admin UI calls its own API)
# AUTH_CORS  = everything that performs login flows (storefront + admin)
STORE_CORS=https://your-storefront-domain.vercel.app
ADMIN_CORS=https://api.yourdomain.tld
AUTH_CORS=https://your-storefront-domain.vercel.app,https://api.yourdomain.tld

# ---- Secrets ----
# Generate with: openssl rand -hex 64
JWT_SECRET=
COOKIE_SECRET=

# ---- File storage (S3-compatible — recommend Cloudflare R2) ----
# Needed for product images and admin uploads.
S3_FILE_URL=https://cdn.yourdomain.tld
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_BUCKET=
S3_ENDPOINT=https://<cf-account-id>.r2.cloudflarestorage.com

# ---- Optional but recommended ----
# Medusa admin email notifications via Resend
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# Sentry for error tracking
# SENTRY_DSN=
