# Postgres — docker compose up -d (port 5433 to avoid conflicts with other local Postgres)
DATABASE_URL=postgres://medusa:medusa@localhost:5433/dyllu_medusa

# CORS (comma-separated)
STORE_CORS=http://localhost:4000,http://localhost:3001
ADMIN_CORS=http://localhost:9000,http://localhost:7001
AUTH_CORS=http://localhost:4000,http://localhost:3001,http://localhost:9000

# Secrets — rotate for production
JWT_SECRET=supersecret-change-me
COOKIE_SECRET=supersecret-change-me

# Storefront revalidation (must match apps/storefront/.env.local REVALIDATE_SECRET)
STOREFRONT_URL=http://localhost:4000
REVALIDATE_SECRET=local-dev-revalidate-secret

# Redis (optional in dev; recommended for prod)
# REDIS_URL=redis://localhost:6379

# Storage (optional in dev; set for prod)
# S3_FILE_URL=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=
# S3_BUCKET=
# S3_ENDPOINT=
