# Medusa backend (local dev: pnpm -F backend dev behind docker compose up -d)
MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API key — create one in /backend (admin UI) under Publishable API Keys
# and attach it to the sales channel the storefront serves
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_replace_me

# Storefront URL
NEXT_PUBLIC_BASE_URL=http://localhost:4000

# Smooth (Lenis) inertial scroll — set to "off" to disable site-wide.
# Auto-disabled when prefers-reduced-motion is on.
# NEXT_PUBLIC_SMOOTH_SCROLL=off
# Set to "off" to disable on touch devices (coarse pointer) only.
# NEXT_PUBLIC_SMOOTH_SCROLL_TOUCH=off

# Image source for marketing visuals — points at Unsplash by default.
# Swap to a Cloudinary fetch base (https://res.cloudinary.com/<cloud>/image/fetch/<url>)
# or any CDN that mirrors the same path layout when real photography is ready.
NEXT_PUBLIC_IMAGE_BASE=https://images.unsplash.com

# On-demand revalidation secret (used by webhooks to invalidate Next cache)
REVALIDATE_SECRET=supersecret

# Optional — S3 image optimization when backend serves from S3-compatible storage
# MEDUSA_CLOUD_S3_HOSTNAME=
# MEDUSA_CLOUD_S3_PATHNAME=
