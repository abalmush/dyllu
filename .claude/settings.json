{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run typecheck)",
      "Bash(npm run check)",
      "Bash(npm run test)",
      "Bash(npm run test:watch)",
      "Bash(npm run test:e2e)",
      "Bash(npm run format)",
      "Bash(npm run format:check)",
      "Bash(npm run build)",
      "Bash(npm run codegen)",
      "Bash(npm run dev)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git show)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(gh pr view)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list)",
      "Bash(gh pr list:*)",
      "Bash(gh issue view)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list)",
      "Bash(gh issue list:*)"
    ]
  }
}
