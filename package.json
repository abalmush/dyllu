{
  "name": "dyllu",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "check": "turbo run check",
    "codegen": "turbo run codegen",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml,css}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.6",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "@babel/core@7.29.0": "7.29.7",
      "@grpc/grpc-js": "1.14.4",
      "@opentelemetry/core@2.7.0": "2.8.0",
      "@opentelemetry/core@2.7.1": "2.8.0",
      "ajv@8.13.0": "8.18.0",
      "axios": "1.18.1",
      "brace-expansion@5.0.5": "5.0.7",
      "esbuild@0.28.0": "0.28.1",
      "fast-xml-builder": "1.3.0",
      "form-data": "4.0.6",
      "json-2-csv@5.5.10": "5.5.11",
      "lodash": "4.18.1",
      "morgan@1.10.1": "1.11.0",
      "multer": "2.2.0",
      "postcss@8.4.31": "8.5.17",
      "protobufjs": "7.6.5",
      "qs@6.14.2": "6.15.3",
      "vite": "6.4.3"
    },
    "onlyBuiltDependencies": [
      "@medusajs/telemetry",
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "msgpackr-extract",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  }
}
